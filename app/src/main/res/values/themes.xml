<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Use Material3 theme and explicitly disable Action Bar -->
    <style name="Theme.Rasaushadhies" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Parchment background to match user image - prevents green flash -->
        <item name="android:windowBackground">#F2EAD3</item>
        <item name="android:colorBackground">#F2EAD3</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- System splash: parchment color -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">#F2EAD3</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/ic_splash_blank</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="31">#F2EAD3</item>
    </style>
</resources>